{
  "name": "repodash",
  "version": "0.1.0",
  "description": "Interactive TUI dashboard for Git repository health",
  "type": "module",
  "bin": {
    "repodash": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts",
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js"
  },
  "keywords": [
    "git",
    "tui",
    "ink",
    "typescript",
    "dashboard"
  ],
  "repository": {
