  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inkjs/ui": "^1.0.0",
    "@octokit/rest": "^22.0.1",
    "@types/react": "^19.2.14",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "date-fns": "^4.1.0",
    "ink": "^4.4.1",
    "react": "^18.3.1",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
